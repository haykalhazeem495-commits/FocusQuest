{
  "manifest_version": 3,
  "name": "FocusQuest",
  "version": "0.1.0",
  "description": "Gamify study sessions by earning XP on educational sites.",
  "permissions": ["tabs", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "FocusQuest",
    "default_popup": "popup/index.html"
  }
}
